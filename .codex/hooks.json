{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/format.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/lint.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/typecheck.sh"
          }
        ]
      }
    ]
  }
}
